<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link href="/css/output.css" rel="stylesheet" />
    <script src="/scripts/login/login.js" defer></script>
  </head>

  <body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">

    <!-- HEADER -->
    <header class="bg-slate-200 text-slate-800 flex flex-col sm:flex-row items-center p-4 gap-4">
      <h1 class="text-xl font-bold">Landing pagina</h1>

      <nav class="flex gap-3 sm:ml-auto">
        <a href="/" class="px-4 py-2 rounded">Home</a>
        <a href="/register" class="px-4 py-2 rounded">Registreren</a>
        <a href="/login" class="bg-black text-white px-4 py-2 rounded">Inloggen</a>
      </nav>
    </header>

    <!-- MAIN -->
    <main class="flex-1 flex justify-center items-start sm:items-center px-0 sm:px-6 py-6 sm:py-10">

      <section class="bg-slate-800 w-full sm:max-w-md p-6 sm:p-8 rounded-none sm:rounded-2xl shadow-lg">

        <h2 class="text-2xl sm:text-3xl font-bold mb-6 text-center">
          Inloggen
        </h2>

        <form id="loginForm" class="flex flex-col gap-4">

          <div id="alertBox" class="hidden p-3 text-sm rounded"></div>

          <input type="email" id="email"
            placeholder="Email"
            class="p-3 text-base rounded bg-slate-700 focus:ring-2 focus:ring-blue-500"
            required />

          <input type="password" id="password"
            placeholder="Password"
            class="p-3 text-base rounded bg-slate-700 focus:ring-2 focus:ring-blue-500"
            required />

          <button
            class="mt-4 bg-blue-600 hover:bg-blue-700 transition py-3 text-lg rounded font-semibold">
            Login
          </button>

        </form>

      </section>

    </main>

  </body>
</html>