<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <title>Login</title>
    <link href="/css/output.css" rel="stylesheet" />    
    <script src="/scripts/login/login.js" defer></script>
  </head>
  

  <body class="bg-slate-900 text-slate-100 text-center sm:text-left"><header
      class="bg-slate-200 text-slate-800 flex flex-col sm:flex-row items-center p-4 gap-4"
    >
      <h1 class="text-xl font-bold">Landing pagina</h1>

      <nav class="flex gap-3 sm:ml-auto">
        <a href="/" class="px-4 py-2 rounded"
          >Home</a
        >
        <a href="/register" class="px-4 py-2 rounded">
          Registreren
        </a>

        <a href="/login" class="bg-black text-white border px-4 py-2 rounded"
          >Inloggen</a
        >
      </nav>
    </header>
    <main class="flex justify-center items-center mt-16 px-6">
      <section class="bg-slate-800 p-8 rounded-2xl w-full max-w-md">
        <h2 class="text-2xl font-bold mb-6 text-center">Inloggen</h2>

        <form id="loginForm" class="flex flex-col gap-4">
          
          <div id="alertBox" class="hidden p-4 text-sm rounded"></div>

          <input
            type="email"
            id="email"
            placeholder="Email"
            required
            class="p-2 rounded bg-slate-700"
          />

          <input
            type="password"
            id="password"
            placeholder="Password"
            required
            class="p-2 rounded bg-slate-700"
          />

          <button class="bg-blue-600 py-2 rounded">Login</button>
        </form>
      </section>
    </main>
  </body>
</html>