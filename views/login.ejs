<%- include ('partials/header') %>

    <header
      class="bg-slate-200 text-slate-800 flex flex-col sm:flex-row items-center p-4 gap-4"
    >
      <h1 class="text-xl font-bold">Inloggen</h1>

      <nav class="flex gap-3 sm:ml-auto">
        <a href="/" class="border px-4 py-2 rounded">Home</a>
        <a href="/register" class="border px-4 py-2 rounded">
          Registreren
        </a>

        <a
          href="/login"
          class="bg-black text-white border px-4 py-2 rounded"
          >Inloggen</a
        >
      </nav>
    </header>

    <!-- LOGIN FORM -->
    <main class="flex justify-center items-center mt-16 px-6">
      <section class="bg-slate-800 p-8 rounded-2xl shadow-lg w-full max-w-md">
        <h2 class="text-2xl font-bold mb-6 text-center">Inloggen</h2>

        <form id="loginForm" class="flex flex-col gap-4">
          <!-- ALERT -->

          <div
            id="alertBox"
            class="hidden flex items-start sm:items-center p-4 mb-4 text-sm text-green-300 rounded bg-green-900 border border-green-700 text-red-300 bg-red-900 border-red-700"
            role="alert"
          >
            <svg
              class="w-4 h-4 me-2 shrink-0 mt-0.5 sm:mt-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-width="2"
                d="M10 11h2v5m-2 0h4m-2.6-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
              />
            </svg>

            <p id="alertText">
              <span class="font-medium me-1">Success!</span> Je bent ingelogd.
            </p>
          </div>
          <!-- EMAIL -->
          <div class="flex flex-col text-left">
            <label for="email" class="mb-1">Email</label>
            <input
              type="email"
              id="email"
              placeholder="voorbeeld@mail.com"
              class="p-2 rounded bg-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
              required
            />
          </div>

          <!-- PASSWORD -->
          <div class="flex flex-col text-left">
            <label for="password" class="mb-1">Wachtwoord</label>
            <input
              type="password"
              id="password"
              placeholder="********"
              class="p-2 rounded bg-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
              required
            />
          </div>

          <!-- BUTTON -->
          <button
            type="submit"
            class="mt-4 bg-blue-600 hover:bg-blue-700 transition px-4 py-2 rounded font-semibold"
          >
            Inloggen
          </button>
        </form>

        <!-- EXTRA -->
        <p class="text-sm mt-6 text-center">
          Nog geen account?
          <a href="./register.html" class="underline hover:text-blue-400"
            >Registreer</a
          >
        </p>
      </section>
    </main>
    
  <%- include('partials/footer') %>

