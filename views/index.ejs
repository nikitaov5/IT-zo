<%- include('partials/header') %>
<header
      class="bg-slate-200 text-slate-800 flex flex-col sm:flex-row items-center p-4 gap-4"
    >
      <h1 class="text-xl font-bold">Landing pagina</h1>

      <nav class="flex gap-3 sm:ml-auto">
        <a href="/" class="bg-black text-white px-4 py-2 rounded"
          >Home</a
        >
        <a href="/register" class="px-4 py-2 rounded">
          Registreren
        </a>

        <a href="/login" class="border px-4 py-2 rounded"
          >Inloggen</a
        >
      </nav>
    </header>

    <main class="mt-10 px-6 sm:px-10 lg:px-16">
      <section
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 justify-items-center"
      >
        <a href="/unavailable" class="text-sm hover:underline">
          <article
            class="flex flex-col items-center gap-3 hover:scale-110 transition"
          >
            <figure class="w-48">
              <img
                src="./assets/images/spotify.png"
                alt="MusicMatch"
                class="w-32 h-32 sm:w-36 sm:h-36 object-contain mx-auto rounded-full"
              />

              <figcaption class="mt-3 text-lg text-center">
                MusicMatch
              </figcaption>
            </figure>

            <p>Meer zien></p>
          </article>
        </a>
        <a href="/home" class="text-sm hover:underline">
          <article
            class="flex flex-col items-center gap-3 hover:scale-110 transition"
          >
            <figure class="w-48">
              <img
                src="./assets/images/gamehub.png"
                alt="GameHub"
                class="w-32 h-32 sm:w-36 sm:h-36 object-contain mx-auto rounded-full"
              />

              <figcaption class="mt-3 text-lg text-center">GameHub</figcaption>
            </figure>

            <p>Meer zien ></p>
          </article>
        </a>
        <a href="/unavailable" class="text-sm hover:underline">
          <article
            class="flex flex-col items-center gap-3 hover:scale-110 transition"
          >
            <figure class="w-48">
              <img
                src="./assets/images/lego.png"
                alt="LegoMaster"
                class="w-32 h-32 sm:w-36 sm:h-36 object-contain mx-auto rounded-full"
              />

              <figcaption class="mt-3 text-lg text-center">
                LegoMaster
              </figcaption>
            </figure>
            <p>Meer zien></p>
          </article>
        </a>
      </section>
    </main>
  <%- include('partials/footer') %>