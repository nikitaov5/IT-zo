<%- include ('partials/header') %>
<title>Compare</title>
<script type="module" src="/scripts/compare/compare.js" defer></script>
<header
      class="fixed top-0 right-0 left-0 bg-slate-200 text-slate-800 flex items-center gap-6 p-4"
    >
      <nav class="flex gap-10">
        <a href="/home">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
            />
          </svg>
        </a>
        <a href="/collection">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z"
            />
          </svg>
        </a>
        <a href="/compare">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
            />
          </svg>
        </a>
        <a href="/gtg">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z"
            />
          </svg>
        </a>
      </nav>
    </header>

    <!-- Main  -->
    <main class="max-w-6xl mx-auto px-6 mt-20 flex flex-col md:flex-row gap-6">
      <!-- Game 1  -->
      <section
        id="game_card_1"
        class="flex-1 bg-slate-800 text-slate-100 shadow-lg overflow-hidden border border-slate-700 rounded-lg"
      >
        <img
          src="../assets/images/no-cover.png"
          alt=""
          class="w-full aspect-video object-cover rounded-lg"
          id="gameImg"
        />
        <div class="px-5 py-2 flex flex-col gap-3">
          <h2 id="gameName" class="text-lg font-bold text-white">Game Naam</h2>
          <ul class="flex flex-col gap-1.5 text-sm text-slate-400">
            <li id="gameGenre">Genre</li>
            <li id="gameRelease">Release</li>
            <li id="gamePlatform">Platform</li>
            <li id="gameRating" class="text-amber-400 font-semibold">Rating</li>
          </ul>
          <input
            type="search"
            placeholder="Zoek een game..."
            class="mt-1 w-full bg-slate-900 text-slate-100 placeholder-slate-500 rounded-lg px-4 py-2 text-sm outline-none transition"
          />
        </div>
      </section>

      <!-- Game 2  -->
      <section
        id="game_card_2"
        class="flex-1 bg-slate-800 text-slate-100 rounded-xl shadow-lg overflow-hidden border border-slate-700 rounded-lg"
      >
        <img
          src="../assets/images/no-cover.png"
          alt=""
          class="w-full aspect-video object-cover rounded-lg"
          id="gameImg2"
        />
        <div class="px-5 py-2 flex flex-col gap-3">
          <h2 id="gameName2" class="text-lg font-bold text-white">Game Naam</h2>
          <ul class="flex flex-col gap-1.5 text-sm text-slate-400">
            <li id="gameGenre2">Genre</li>
            <li id="gameRelease2">Release</li>
            <li id="gamePlatform2">Platform</li>
            <li id="gameRating2" class="text-amber-400 font-semibold">
              Rating
            </li>
          </ul>
          <input
            type="search"
            placeholder="Zoek een game..."
            class="mt-1 w-full bg-slate-900 text-slate-100 placeholder-slate-500 rounded-lg px-4 py-2 text-sm outline-none transition"
          />
        </div>
      </section>
    </main>
<%- include ('partials/footer') %>
